{
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@rollup/plugin-node-resolve": "^16.0.2",
        "@rollup/plugin-replace": "^6.0.3",
        "@rollup/plugin-terser": "^0.4.4",
        "c8": "^10.1.3",
        "eslint": "^9.39.1",
        "eslint-plugin-import": "^2.32.0",
        "html-minifier-terser": "^7.2.0",
        "prettier": "^3.6.2",
        "rollup": "^4.52.0"
    },
    "scripts": {
        "lint": "eslint",
        "test": "node --test",
        "test_c": "c8 --all --include 'packages/**/src/**/*.mjs' --exclude '**/index.mjs' node --test",
        "test_r": "c8 --all --reporter=html --include 'packages/**/src/**/*.mjs' --exclude '**/index.mjs' node --test"
    }
}
